# 复制本文件为 .env.local 并填入真实 key（.env.local 已被 .gitignore 忽略，绝不提交）
#   cp .env.local.example .env.local
# 然后 ./start.sh 启动

CODA_LLM_BACKEND=openai
# 中转站地址——注意是 api. 开头，不是浏览器里那个 credits.
OPENAI_BASE_URL=https://api.openai-next.com/v1
# 主办方控制台「API Key」标签里那把（sk-DY7H… 那种），不是 OpenAI 官方的 sk-proj-…
OPENAI_API_KEY=sk-在这里填你的中转站key
CODA_LLM_MODEL=gpt-4o-mini
